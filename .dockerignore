# Version control
.git
.github

# Python bytecode — never goes into the image
__pycache__
*.pyc
*.pyo
*.pyd

# Test suite — not needed at runtime
tests/

# Claude Code agent config — credentials/secrets must not be baked in
.claude/

# Node (not used, but guard against accidental node_modules in workspace)
node_modules/

# Dev / build artifacts
*.sh.bak
*.log
build/
dist/

# Local overrides
.env
.env.local
config.json.bak

# macOS noise
.DS_Store
