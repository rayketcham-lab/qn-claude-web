# QN Code Assistant - Systemd Service
#
# To install:
#   sudo cp qn-code-assistant.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable qn-code-assistant
#   sudo systemctl start qn-code-assistant
#
# To view logs:
#   sudo journalctl -u qn-code-assistant -f

[Unit]
Description=QN Code Assistant
After=network.target

[Service]
Type=simple
# Set User and Group to match the system user that owns /opt/claude-web
User=pleb
Group=pleb
WorkingDirectory=/opt/claude-web
ExecStart=/usr/bin/python3 /opt/claude-web/app.py
Restart=on-failure
RestartSec=5
KillMode=process
Environment=PYTHONUNBUFFERED=1
Environment=CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/opt/claude-web/sessions /opt/claude-web/backups /opt/claude-web/certs
ReadWritePaths=/opt/claude-web/config.json /opt/claude-web/usage.json
ReadWritePaths=/opt/claude-web/audit.log /opt/claude-web/auth.json /opt/claude-web/user-data
ReadWritePaths=/home/pleb/.claude/agent-logs
CapabilityBoundingSet=
RestrictSUIDSGID=true

[Install]
WantedBy=multi-user.target
